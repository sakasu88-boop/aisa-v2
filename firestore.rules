rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Custom Claims（主キー）: role, chainId, storeId（主所属）
    // Firestore users/{uid}.accessibleStores で複数店舗を補助（ルール内 get）
    // 注意: get() は評価ごとに課金対象。クレームで済む範囲はクレーム優先。
    // -------------------------------------------------------------------------

    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() ? request.auth.token.role : '';
    }

    function chainIdClaim() {
      return signedIn() && request.auth.token.chainId is string
        ? request.auth.token.chainId
        : '';
    }

    function storeIdClaim() {
      return signedIn() && request.auth.token.storeId is string
        ? request.auth.token.storeId
        : '';
    }

    function isChainAdmin() {
      return signedIn() && role() == 'chain_admin';
    }

    function isStoreStaff() {
      return signedIn() && role() == 'store_staff';
    }

    function chainAdminOwnsChainId(cid) {
      return isChainAdmin()
        && chainIdClaim() != ''
        && cid == chainIdClaim();
    }

    // 店舗スタッフ: トークンの主所属 storeId、または users/{uid}.accessibleStores に含まれる店舗
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userHasAccessibleStoresList() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().keys().hasAny(['accessibleStores'])
        && userDoc().accessibleStores is list;
    }

    // 左側を先に評価: 主所属（Claims の storeId）一致時は get(users/...) を評価しない（短絡）
    function storeStaffMayAccessStoreId(sid) {
      return isStoreStaff()
        && chainIdClaim() != ''
        && sid is string
        && sid != ''
        && (
          sid == storeIdClaim()
          || (
            userHasAccessibleStoresList()
            && sid in userDoc().accessibleStores
          )
        );
    }

    function chainAdminCanAccessDocData() {
      return resource.data.keys().hasAll(['chainId'])
        && chainAdminOwnsChainId(resource.data.chainId);
    }

    function storeStaffCanAccessDocData() {
      return resource.data.keys().hasAll(['chainId', 'storeId'])
        && resource.data.chainId == chainIdClaim()
        && storeStaffMayAccessStoreId(resource.data.storeId);
    }

    // パス上の storeId とドキュメントの storeId を一致させる（改ざん防止）
    function docStoreIdMatchesPath(storeId) {
      return resource.data.keys().hasAll(['storeId'])
        && resource.data.storeId == storeId;
    }

    function createChainAdminWritesStoreDoc(storeId) {
      return request.resource.data.keys().hasAll(['chainId', 'storeId'])
        && chainAdminOwnsChainId(request.resource.data.chainId)
        && request.resource.data.storeId == storeId;
    }

    function createChainAdminWritesOwnChain() {
      return request.resource.data.keys().hasAll(['chainId'])
        && chainAdminOwnsChainId(request.resource.data.chainId);
    }

    function createStoreStaffWritesOwnStore() {
      return request.resource.data.keys().hasAll(['storeId', 'chainId'])
        && request.resource.data.chainId == chainIdClaim()
        && storeStaffMayAccessStoreId(request.resource.data.storeId);
    }

    // -------------------------------------------------------------------------
    // users/{uid} — プロフィール（Claims と同期するメタ。クライアント直接更新は禁止）
    // -------------------------------------------------------------------------
    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // chains
    // -------------------------------------------------------------------------
    match /chains/{chainId} {
      allow read: if signedIn() && chainAdminOwnsChainId(chainId);

      allow create: if signedIn()
        && isChainAdmin()
        && chainIdClaim() == chainId
        && request.resource.data.keys().hasAll(['chainId'])
        && request.resource.data.chainId == chainId;

      allow update, delete: if signedIn()
        && chainAdminOwnsChainId(chainId)
        && resource.data.chainId == chainId
        && request.resource.data.chainId == chainId;
    }

    // -------------------------------------------------------------------------
    // stores
    // -------------------------------------------------------------------------
    match /stores/{storeId} {
      allow read: if signedIn() && (
        (isChainAdmin() && chainAdminCanAccessDocData() && docStoreIdMatchesPath(storeId))
        || (isStoreStaff() && storeStaffCanAccessDocData() && docStoreIdMatchesPath(storeId))
      );

      allow create: if signedIn() && (
        createChainAdminWritesStoreDoc(storeId)
        || createStoreStaffWritesOwnStore()
      );

      allow update, delete: if signedIn() && (
        (isChainAdmin() && chainAdminCanAccessDocData() && docStoreIdMatchesPath(storeId))
        || (isStoreStaff() && storeStaffCanAccessDocData() && docStoreIdMatchesPath(storeId))
      );

      // 店舗配下（例: マップ上のピン・棚）— 親パス storeId と data.storeId を一致
      match /items/{itemId} {
        allow read: if signedIn() && (
          (isChainAdmin() && chainAdminCanAccessDocData() && docStoreIdMatchesPath(storeId))
          || (isStoreStaff() && storeStaffCanAccessDocData() && docStoreIdMatchesPath(storeId))
        );

        allow create: if signedIn() && (
          createChainAdminWritesStoreDoc(storeId)
          || createStoreStaffWritesOwnStore()
        );

        allow update, delete: if signedIn() && (
          (isChainAdmin() && chainAdminCanAccessDocData() && docStoreIdMatchesPath(storeId))
          || (isStoreStaff() && storeStaffCanAccessDocData() && docStoreIdMatchesPath(storeId))
        );
      }
    }

    // -------------------------------------------------------------------------
    // products（トップレベル）
    // -------------------------------------------------------------------------
    match /products/{productId} {
      allow read: if signedIn() && (
        (isChainAdmin() && chainAdminCanAccessDocData())
        || (isStoreStaff() && storeStaffCanAccessDocData())
      );

      allow create: if signedIn() && (
        createChainAdminWritesOwnChain()
        || createStoreStaffWritesOwnStore()
      );

      allow update, delete: if signedIn() && (
        (isChainAdmin() && chainAdminCanAccessDocData())
        || (isStoreStaff() && storeStaffCanAccessDocData())
      );
    }

    // -------------------------------------------------------------------------
    // categories
    // -------------------------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if signedIn() && (
        (isChainAdmin() && chainAdminCanAccessDocData())
        || (isStoreStaff() && storeStaffCanAccessDocData())
      );

      allow create: if signedIn() && (
        createChainAdminWritesOwnChain()
        || createStoreStaffWritesOwnStore()
      );

      allow update, delete: if signedIn() && (
        (isChainAdmin() && chainAdminCanAccessDocData())
        || (isStoreStaff() && storeStaffCanAccessDocData())
      );
    }

    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
