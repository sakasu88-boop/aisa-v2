# Algolia — 一般客向けは Search-Only API Key のみ（Admin Key は絶対に置かない）
# Algolia ダッシュボード → API Keys → Search-Only API Key をコピー

VITE_ALGOLIA_APP_ID=your_algolia_application_id
VITE_ALGOLIA_SEARCH_API_KEY=your_search_only_api_key
VITE_ALGOLIA_INDEX_NAME=prod_items

# 既定の店舗フィルタ（任意）。未設定ならフィルタなしで全店舗ヒット（Search-Only Key の制限内）
VITE_DEFAULT_STORE_ID=
