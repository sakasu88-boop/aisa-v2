# ---------------------------------------------------------------------------
# AISA admin-app — Firebase Web (Vite)
# ---------------------------------------------------------------------------
# 使い方: このファイルをコピーして .env を作成し、Firebase コンソールの値に置き換えてください。
#   cp .env.example .env
#
# コミット対象: .env.example のみ（.env は絶対にコミットしない）
#
# Firebase コンソールで確認すること:
# - プロジェクト設定 → 全般 → マイアプリ → SDK の設定と構成
# - Authentication → 設定 → 承認済みドメイン に、開発時は「localhost」を含める
#   （本番 URL をデプロイしたら、そのドメインも追加する）
# =============================================================================

VITE_FIREBASE_API_KEY=dummy_api_key_replace_me
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:aaaaaaaaaaaaaaaaaaaaaa
